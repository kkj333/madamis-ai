# コピー: cp .env.example .env
# Gemini / ADK 用（チャット API で必須）

GOOGLE_API_KEY=

# ADK session persistence. Omit or set in_memory for local ephemeral sessions.
# ADK_SESSION_SERVICE=firestore
# FIRESTORE_PROJECT_ID=
# FIRESTORE_DATABASE_ID=(default)
# ADK_FIRESTORE_ROOT_COLLECTION=adk-session

# 省略時 INFO。詳細ログは DEBUG
# LOG_LEVEL=DEBUG
